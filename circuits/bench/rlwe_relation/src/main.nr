global COEFF_COUNT: u32 = 64;

fn main(c0: [Field; COEFF_COUNT], c1: [Field; COEFF_COUNT], s: [Field; COEFF_COUNT], m: [Field; COEFF_COUNT], e: [Field; COEFF_COUNT]) {
    for i in 0..COEFF_COUNT {
        assert(c0[i] + c1[i] * s[i] == m[i] + e[i]);
    }
}

