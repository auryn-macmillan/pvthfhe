pragma solidity ^0.8.24;

import "forge-std/Test.sol";
import "../src/generated/HonkVerifier.sol";

/// @title HonkVerifierRealProofTest
/// @notice Feeds a real (non-ZK) UltraHonk proof from aggregator_final
///         into HonkVerifier.sol and asserts the verifier ACCEPTS.
///
    ///         Proof regenerated 2026-05-17: bb prove --verifier_target evm-no-zk
    ///         Proof/public inputs are read from circuits/target.
///         VK matches: VK_HASH confirmed identical to on-disk vk_hash.
contract HonkVerifierRealProofTest is Test {
    HonkVerifier internal honk;

    function setUp() public {
        honk = new HonkVerifier();
    }

    function test_real_proof_accepts() public view {
        bytes memory proof = vm.readFileBinary("../circuits/target/proof");

        bytes memory publicInputBytes = vm.readFileBinary("../circuits/target/public_inputs");
        require(publicInputBytes.length % 32 == 0, "public inputs must be field-aligned");
        bytes32[] memory publicInputs = new bytes32[](publicInputBytes.length / 32);
        for (uint256 i = 0; i < publicInputs.length; i++) {
            bytes32 value;
            assembly {
                value := mload(add(add(publicInputBytes, 0x20), mul(i, 0x20)))
            }
            publicInputs[i] = value;
        }

        bool result = honk.verify(proof, publicInputs);
        assertTrue(result, "real UltraHonk proof must be accepted");
    }

    function buildRealProof() internal pure returns (bytes memory) {
        return bytes.concat(
            bytes(hex""),
            bytes(hex""),
            bytes(hex""),
            bytes(hex""),
            bytes(hex""),
            bytes(hex""),
            bytes(hex""),
            bytes(hex"")
        );
    }
}
